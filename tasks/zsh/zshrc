# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your oh-my-zsh installation.
export ZSH="/Users/bob/.oh-my-zsh"

export PATH="$HOME/.local/bin:$PATH"

# dotfiles-managed zsh completions (e.g. _dotbrew). Must precede compinit.
fpath=("${DOTFILES_PATH:-$HOME/.dotfiles}/tasks/dotbrew" $fpath)

export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
export PIPENV_PYTHON="$PYENV_ROOT/shims/python"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="powerlevel10k/powerlevel10k"
# ZSH_THEME="robbyrussell"

plugins=(
  git
  ssh-agent
  aws
  terraform
  docker
  pyenv
  mise
  zsh-autosuggestions
  zsh-syntax-highlighting # Must go at end of config list
)

eval "$(/opt/homebrew/bin/brew shellenv)"

eval "$(direnv hook zsh)"

eval "$(pyenv init --path)"
eval "$(pyenv virtualenv-init -)"
eval "$(/opt/homebrew/bin/brew shellenv)"

# tabtab source for packages
# uninstall by removing these lines
[[ -f ~/.config/tabtab/__tabtab.zsh ]] && . ~/.config/tabtab/__tabtab.zsh || true

# OpenJDK (via Homebrew) — only fires if installed.
[[ -d /opt/homebrew/opt/openjdk/bin ]] && export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"

# Added by serverless binary installer
export PATH="$HOME/.serverless/bin:$PATH"

source $ZSH/oh-my-zsh.sh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# dotfiles: warn on shell startup if installed brew packages aren't tracked in
# any Brewfile. Checks formulae + casks (mas + vscode entries skipped for speed).
dotfiles_brew_drift_check() {
  [[ -o interactive ]] || return 0
  local DOTFILES="${DOTFILES_PATH:-$HOME/.dotfiles}"
  [[ -f "$DOTFILES/Brewfile" ]] || return 0
  command -v brew >/dev/null 2>&1 || return 0

  local tracked=$(
    cat "$DOTFILES/Brewfile" "$DOTFILES/tools.Brewfile" "$DOTFILES/additional.Brewfile" 2>/dev/null \
      | awk -F'"' '/^(brew|cask)[[:space:]]+"/ { print $2 }'
  )
  local ignored=""
  if [[ -f "$DOTFILES/.brewfileignore" ]]; then
    # Accept: "name", "type:name", or Brewfile-style `brew "name"` / `cask "name"` / etc.
    ignored=$(
      grep -Ev '^[[:space:]]*(#|$)' "$DOTFILES/.brewfileignore" \
        | sed -E \
            -e 's/^[[:space:]]*(tap|brew|cask|mas|vscode)[[:space:]]+"([^"]+)".*$/\2/' \
            -e 's/^[[:space:]]*(tap|brew|cask|mas|vscode):(.+)$/\2/' \
            -e 's/^[[:space:]]+//;s/[[:space:]]+$//'
    )
  fi
  # `brew leaves` lists user-intent formulae only (skips transitive deps).
  local installed=$({ brew leaves 2>/dev/null; brew list --cask -1 2>/dev/null; })

  local untracked=$(
    comm -23 <(echo "$installed" | sort -u) <(printf '%s\n%s\n' "$tracked" "$ignored" | sort -u)
  )
  if [[ -n "$untracked" ]]; then
    local count=$(echo "$untracked" | wc -l | tr -d ' ')
    print -P "%F{yellow}dotfiles: $count untracked brew package(s) — run 'mise run brew:generate' in $DOTFILES%f"
    echo "$untracked" | head -3 | sed 's/^/  /'
    (( count > 3 )) && echo "  ... and $((count - 3)) more"
  fi
}
dotfiles_brew_drift_check
