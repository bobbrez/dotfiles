if [[ -d ~/.oh-my-zsh/.git ]]; then
  echo "OhMyZSH already installed, checking for deltas"
  git -C ~/.oh-my-zsh fetch --quiet origin master
  behind=$(git -C ~/.oh-my-zsh rev-list --count HEAD..origin/master)
  ahead=$(git -C ~/.oh-my-zsh rev-list --count origin/master..HEAD)
  local_changes=$(git -C ~/.oh-my-zsh status --short)

  if [[ -n "$local_changes" ]]; then
    echo "\nLocal modifications:"
    echo "$local_changes"
  fi
  if (( behind > 0 )); then
    echo "\n$behind commit(s) behind upstream:"
    git -C ~/.oh-my-zsh log --oneline HEAD..origin/master | head -20
  fi
  if (( ahead > 0 )); then
    echo "\n$ahead local commit(s) ahead of upstream"
  fi
  if [[ -z "$local_changes" ]] && (( behind == 0 && ahead == 0 )); then
    echo "Up to date with upstream"
  fi
else
  # Install OhMyZsh
  sh -c "export RUNZSH=no && $(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

  # Replace the generated zshrc with the custom one here, the backup should be discared aferwards
  mv ~/.zshrc ~/.zshrc.bkup
  ln -s "${0:a:h}/zshrc" ~/.zshrc
fi

# Install / update Powerlevel10k
local P10K_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k"
if [[ -d "$P10K_DIR/.git" ]]; then
  echo "Updating powerlevel10k"
  git -C "$P10K_DIR" pull --quiet
else
  echo "Installing powerlevel10k"
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR"
fi
ln -sf "${0:a:h}/p10k.zsh" ~/.p10k.zsh

# Install / update Powerline fonts
local FONTS_DIR="$HOME/.powerline-fonts"
if [[ -d "$FONTS_DIR/.git" ]]; then
  echo "Updating powerline fonts"
  git -C "$FONTS_DIR" pull --quiet
else
  echo "Installing powerline fonts"
  git clone --depth=1 https://github.com/powerline/fonts.git "$FONTS_DIR"
fi
"$FONTS_DIR/install.sh"