if ! command -v op &> /dev/null; then
  echo "1Password CLI (op) not found."
  echo ""
  echo "Install the 1Password desktop app from https://1password.com/downloads,"
  echo "then enable the CLI integration:"
  echo "  1Password → Settings → Developer → 'Integrate with 1Password CLI'"
  echo ""
  read "?Press enter once op is installed and CLI integration is enabled... "
fi

while :; do
  accounts=$(op account list --format=json 2>/dev/null)
  if [[ -n "$accounts" && "$accounts" != "[]" ]]; then
    break
  fi

  echo ""
  echo "1Password CLI is not connected to any accounts."
  echo ""
  echo "In the 1Password desktop app, please:"
  echo "  1. Sign in to your 1Password account(s)"
  echo "  2. Settings → Developer → enable 'Integrate with 1Password CLI'"
  echo "  3. Settings → Developer → enable 'Use the system authentication service' (Touch ID)"
  echo ""
  read "?Press enter once complete to re-check... "
done

echo "1Password CLI connected:"
op account list

local KEYS_FILE="${0:a:h}/1password_keys"
local CONFIGURE_SCRIPT="${0:a:h}/configure"

while [[ ! -f "$KEYS_FILE" ]]; do
  echo ""
  echo "No $KEYS_FILE — launching configure to pick SSH keys from 1Password"
  echo ""
  "$CONFIGURE_SCRIPT"
  echo ""
  read "?Press enter once finished to continue... "
  if [[ ! -f "$KEYS_FILE" ]]; then
    echo "$KEYS_FILE still missing — re-running configure."
  fi
done

mkdir -p ~/.ssh
chmod 700 ~/.ssh

echo ""
echo "Syncing SSH keys from 1Password → ~/.ssh"

local line fname vid iid priv pub
while IFS= read -r line; do
  [[ -z "$line" || "$line" == \#* ]] && continue
  read -r fname vid iid <<< "$line"
  [[ -z "$fname" || -z "$vid" || -z "$iid" ]] && continue

  priv=~/.ssh/$fname
  pub=~/.ssh/$fname.pub

  if [[ -f "$priv" ]]; then
    echo "  $fname already present — skipping fetch (delete to re-sync)"
  else
    echo "  Fetching $fname from 1Password..."
    if op read "op://$vid/$iid/private key?ssh-format=openssh" > "$priv.tmp" 2>/dev/null; then
      mv "$priv.tmp" "$priv"
      chmod 600 "$priv"
    else
      rm -f "$priv.tmp"
      echo "    failed to fetch private key for $fname"
      continue
    fi

    if op read "op://$vid/$iid/public key" > "$pub.tmp" 2>/dev/null; then
      mv "$pub.tmp" "$pub"
      chmod 644 "$pub"
    else
      rm -f "$pub.tmp"
    fi
  fi

  echo "  Adding $fname to ssh-agent (Apple keychain)"
  ssh-add --apple-use-keychain "$priv" || echo "    ssh-add failed for $fname"
done < "$KEYS_FILE"
