#!/usr/bin/env bash
#MISE description="Apply 1Password setup (bundle + check + init shell plugins)"
#MISE depends=["1password:check"]
set -euo pipefail

PLUGINS_USED_DIR="$HOME/.config/op/plugins/used_items"

ensure_op_plugin() {
  local plugin=$1
  local marker="$PLUGINS_USED_DIR/$plugin.json"
  if [[ -s "$marker" ]] && [[ "$(cat "$marker")" != "[]" ]]; then
    echo "  $plugin plugin already configured"
    return 0
  fi
  echo
  echo "Configuring 1Password shell plugin: $plugin"
  op plugin init "$plugin"
}

for plugin in aws cdk; do
  ensure_op_plugin "$plugin"
done
