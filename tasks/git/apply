#!/usr/bin/env bash
#MISE description="Symlink gitconfig/gitignore and pin origin remote"
set -euo pipefail

source "$MISE_PROJECT_ROOT/lib/symlink.sh"

link_dotfile "$MISE_PROJECT_ROOT/tasks/git/gitignore" "$HOME/.gitignore"
link_dotfile "$MISE_PROJECT_ROOT/tasks/git/gitconfig" "$HOME/.gitconfig"

ORIGIN_URL="git@github.com:bobbrez/dotfiles.git"
current=$(git -C "$MISE_PROJECT_ROOT" remote get-url origin 2>/dev/null || true)
if [[ "$current" == "$ORIGIN_URL" ]]; then
  echo "origin already set to $ORIGIN_URL, skipping"
elif [[ -z "$current" ]]; then
  echo "Adding origin -> $ORIGIN_URL"
  git -C "$MISE_PROJECT_ROOT" remote add origin "$ORIGIN_URL"
else
  echo "Updating origin: $current -> $ORIGIN_URL"
  git -C "$MISE_PROJECT_ROOT" remote set-url origin "$ORIGIN_URL"
fi
