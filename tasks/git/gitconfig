  email = 143331+bobbrez@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAICz9WRiwjxWmEUM9daLY/O1xPenvMvPT/0KF8icUE8Es

[github]
  user = bobbrez

[core]
  editor = code
  whitespace = fix,indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore

[include]
  path = ~/.gitconfig.credentials

[color]
  ui = auto
  branch = auto
  diff = auto
  interactive = auto
  status = auto

[alias]
  a = add --all
  c = commit
  cm = commit -m
  cam = commit -am
  fu = fetch upstream
  co = checkout
  cob = checkout -b
  st = status
  br = branch -av

[credential]
	helper = cache

[init]
	defaultBranch = main

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
	gpgsign = true
