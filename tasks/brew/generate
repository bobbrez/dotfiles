#!/usr/bin/env bash
#MISE description="Regenerate root Brewfile, tools.Brewfile, additional.Brewfile from task Brewfiles + installed state"
#MISE depends=["brew:install"]
set -euo pipefail

ROOT="$MISE_PROJECT_ROOT"
TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

ENTRY_RE='^(tap|brew|cask|mas|vscode)[[:space:]]+"([^"]+)"'
IGNORE_TYPED_RE='^(tap|brew|cask|mas|vscode):(.+)$'

# Emit (type<TAB>name<TAB>line) for each valid entry in a Brewfile.
parse_brewfile() {
  local f="$1"
  [[ -f "$f" ]] || return 0
  # `|| [[ -n $raw ]]` catches a final line that lacks a trailing newline.
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local trimmed="${raw#"${raw%%[![:space:]]*}"}"
    [[ -z "$trimmed" || "$trimmed" == \#* ]] && continue
    if [[ "$trimmed" =~ $ENTRY_RE ]]; then
      printf '%s\t%s\t%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "$trimmed"
    fi
  done < "$f"
}

# Parse .brewfileignore into two streams of keys:
#   - typed:  "type|name"   (specific: cask:docker-desktop or brew "foo")
#   - bare:   "name"        (applies to all types)
parse_ignore() {
  local f="$1"
  [[ -f "$f" ]] || return 0
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    local trimmed="${raw#"${raw%%[![:space:]]*}"}"
    trimmed="${trimmed%"${trimmed##*[![:space:]]}"}"
    [[ -z "$trimmed" || "$trimmed" == \#* ]] && continue
    if [[ "$trimmed" =~ $ENTRY_RE ]]; then
      printf 'typed\t%s|%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
    elif [[ "$trimmed" =~ $IGNORE_TYPED_RE ]]; then
      printf 'typed\t%s|%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
    else
      printf 'bare\t%s\n' "$trimmed"
    fi
  done < "$f"
}

collect_task_entries() {
  local suffix="$1"
  local d
  for d in "$ROOT"/tasks/*/; do
    parse_brewfile "$d$suffix"
  done
}

# Read (type<TAB>name<TAB>line) from stdin, dedupe by (type, name),
# emit full lines sorted by (type-order, name).
sort_unique() {
  awk -F'\t' '
    BEGIN { order["tap"]=1; order["brew"]=2; order["cask"]=3; order["mas"]=4; order["vscode"]=5 }
    {
      key = $1 "|" $2
      if (!(key in seen)) {
        seen[key] = 1
        typeord[key] = order[$1]
        name[key] = $2
        line[key] = $3
      }
    }
    END { for (k in seen) print typeord[k] "\t" name[k] "\t" line[k] }
  ' | sort -k1,1n -k2,2 | cut -f3-
}

BREWFILE_HEADER='# Generated by `mise run brew:generate`. Do not edit.
# Source: union of tasks/*/Brewfile.'

TOOLS_HEADER='# Generated by `mise run brew:generate`. Do not edit.
# Source: union of tasks/*/tools.Brewfile.'

ADDITIONAL_HEADER='# User extras not owned by any task Brewfile.
# Populated by `mise run brew:generate` from `brew bundle dump` minus task-owned entries.
# Safe to edit by hand; re-running brew:generate preserves your entries.'

echo "==> Collecting target entries from tasks/*/Brewfile"
collect_task_entries "Brewfile" > "$TMP/target_raw"

echo "==> Collecting tool entries from tasks/*/tools.Brewfile"
collect_task_entries "tools.Brewfile" > "$TMP/tools_raw"

{ cat "$TMP/target_raw"; cat "$TMP/tools_raw"; } \
  | awk -F'\t' '{ print $1 "|" $2 }' | sort -u > "$TMP/owned_keys"

echo "==> Dumping currently installed Homebrew state"
brew bundle dump --file="$TMP/dump" --force

echo "==> Parsing .brewfileignore (if any)"
parse_ignore "$ROOT/.brewfileignore" > "$TMP/ignore_raw"
awk -F'\t' '$1 == "typed" { print $2 }' "$TMP/ignore_raw" | sort -u > "$TMP/ignore_typed"
awk -F'\t' '$1 == "bare"  { print $2 }' "$TMP/ignore_raw" | sort -u > "$TMP/ignore_bare"

echo "==> Computing additional entries (installed + existing_additional - owned - ignored)"
{
  parse_brewfile "$TMP/dump"
  parse_brewfile "$ROOT/additional.Brewfile"
} | awk -F'\t' \
      -v OWNED_FILE="$TMP/owned_keys" \
      -v IGTYPE_FILE="$TMP/ignore_typed" \
      -v IGBARE_FILE="$TMP/ignore_bare" '
  BEGIN {
    while ((getline line < OWNED_FILE)  > 0) owned[line]     = 1; close(OWNED_FILE)
    while ((getline line < IGTYPE_FILE) > 0) ig_typed[line]  = 1; close(IGTYPE_FILE)
    while ((getline line < IGBARE_FILE) > 0) ig_bare[line]   = 1; close(IGBARE_FILE)
  }
  {
    key = $1 "|" $2
    if (key in owned)     next
    if (key in ig_typed)  next
    if ($2 in ig_bare)    next
    print
  }
' > "$TMP/additional_raw"

{
  printf '%s\n\n' "$BREWFILE_HEADER"
  sort_unique < "$TMP/target_raw"
} > "$ROOT/Brewfile"

{
  printf '%s\n\n' "$TOOLS_HEADER"
  sort_unique < "$TMP/tools_raw"
} > "$ROOT/tools.Brewfile"

{
  printf '%s\n\n' "$ADDITIONAL_HEADER"
  sort_unique < "$TMP/additional_raw"
} > "$ROOT/additional.Brewfile"

echo
echo "Wrote:"
for f in Brewfile tools.Brewfile additional.Brewfile; do
  count=$(grep -cE '^[[:space:]]*(tap|brew|cask|mas|vscode)[[:space:]]' "$ROOT/$f" || true)
  printf '  %-24s %3d entries\n' "$f" "$count"
done
