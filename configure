#!/usr/bin/env zsh
set -e

DOTFILES_PATH=${DOTFILES_PATH:="${0:a:h}"}
TASKS_DIR="$DOTFILES_PATH/tasks"

name="$1"
if [[ -z "$name" || "$name" == "-h" || "$name" == "--help" ]]; then
  print "Usage: configure <task>"
  print
  print "Runs tasks/<task>/configure. Tasks with a configure script:"
  for d in $TASKS_DIR/*(N/); do
    [[ -x "$d/configure" ]] && print "  ${d:t}"
  done
  [[ -z "$name" ]] && exit 1 || exit 0
fi

script="$TASKS_DIR/$name/configure"
if [[ ! -x "$script" ]]; then
  print -u2 "error: no configure script for task '$name' (expected $script)"
  exit 1
fi

shift
exec "$script" "$@"
